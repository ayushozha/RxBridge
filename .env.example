# Copy this file to .env.local and fill in your real key.
#   cp .env.example .env.local

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
# Keep it server side only, never prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=sk-proj-...

# Realtime speech to speech model. Defaults to gpt-realtime-2 if unset.
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Assistant voice. Defaults to marin if unset.
OPENAI_REALTIME_VOICE=marin

# Model for the typed text chat mode. Defaults to gpt-5.5 if unset.
OPENAI_CHAT_MODEL=gpt-5.5

# Your xAI / Grok API key. Get one at https://console.x.ai
# Used server side for realtime health news (outbreaks, drug shortages).
XAI_API_KEY=xai-...

# Grok model for the realtime news subagent. Defaults to grok-4.3 if unset.
XAI_MODEL=grok-4.3

# Fast, low latency Grok model for realtime chart explanations.
XAI_FAST_MODEL=grok-4.20-0309-non-reasoning

# Vercel AI Gateway key, optional, for routing model calls through Vercel.
AI_GATEWAY_API_KEY=vck_...

# Vercel deploy credentials, used by tooling and CI, not by the app at runtime.
VERCEL_TEAM_ID=team_...
VERCEL_API_TOKEN=vcp_...

# Vercel KV (Upstash Redis) for the rescue case store, so the multi step rescue
# flow survives across serverless instances. Auto injected when you connect a KV
# store to the project. Locally, leave unset to use the in memory fallback.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
